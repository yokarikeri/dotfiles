# ~/.gitconfig -> ~/.config/git/config
# Machine-local overrides (credential.helper, user.*) live in config.local,
# auto-generated by .config/zsh/conf.d/13-git.zsh on the first shell start.

[core]
    editor = nvim
    pager = delta
[rebase]
    autoStash = true
[commit]
    verbose = true
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
[merge]
    conflictstyle = zdiff3
[diff]
    colorMoved = default
[include]
    path = config.local
