{
  "effortLevel": "medium",
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./**/credentials*)",
      "Read(./**/id_rsa*)",
      "Read(./**/id_ed25519*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(/etc/shadow)",
      "Read(/etc/sudoers)",
      "Read(/etc/sudoers.d/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf --no-preserve-root*)",
      "Bash(sudo rm *)",
      "Bash(dd if=* of=/dev/sd*)",
      "Bash(mkfs.* /dev/sd*)",
      "Bash(chmod -R 777 /*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(eval *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git push --force-with-lease origin master*)",
      "Bash(git reset --hard origin*)",
      "Bash(git clean -fdx*)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(git push *)",
      "Bash(git reset --hard*)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(pip install *)",
      "Bash(pipx install *)",
      "Bash(npm install -g *)",
      "Bash(brew install *)",
      "Bash(docker push *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": false,
    "network": {
      "allowAllUnixSockets": true
    }
  }
}
